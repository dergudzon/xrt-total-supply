# Port exposed on the host machine
APP_PORT=3000

# Port the app listens on inside the container
PORT=3000

# Bind address inside the container
HOST=0.0.0.0

# Robonomics parachain RPC endpoint
ROBONOMICS_WS=wss://polkadot.rpc.robonomics.network/

# Polkadot Asset Hub RPC endpoint
ASSET_HUB_WS=wss://polkadot-asset-hub-rpc.polkadot.io

# Response cache TTL in milliseconds
CACHE_TTL_MS=10000
